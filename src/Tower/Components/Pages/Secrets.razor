@page "/secrets"
@using Tower.Core.Models
@using Tower.Core.Secrets
@inject SecretService SecretSvc

<PageTitle>Tower — Passwords</PageTitle>

<div class="secrets-page">

    <div class="secrets-head">
        <h1 class="page-title">Passwords</h1>
        @if (SecretSvc.IsConfigured && SecretSvc.IsUnlocked)
        {
            <button class="btn-secondary btn-sm" @onclick="Lock">Lock</button>
        }
    </div>

    @if (!SecretSvc.IsConfigured)
    {
        @* ── First run: set the master password ──────────────────────────────── *@
        <section class="atom-section-block secrets-form secrets-gate">
            <div class="atom-block-title">Set a master password</div>
            <p class="secrets-sub">
                This encrypts every stored password at rest. There is <strong>no recovery</strong> —
                if you forget it, the stored values cannot be decrypted.
            </p>
            <div class="config-form">
                <div class="config-row">
                    <label class="config-label">Master password</label>
                    <input type="password" class="config-input config-input-wide" @bind="_pw1" @bind:event="oninput" />
                </div>
                <div class="config-row">
                    <label class="config-label">Confirm</label>
                    <input type="password" class="config-input config-input-wide" @bind="_pw2" @bind:event="oninput"
                           @onkeydown="@(e => { if (e.Key == "Enter") return Configure(); return Task.CompletedTask; })" />
                </div>
                <div class="config-row">
                    <label class="config-label"></label>
                    <div>
                        <button class="btn-primary btn-sm" disabled="@(!CanConfigure)" @onclick="Configure">Set &amp; encrypt</button>
                        @if (_error is not null) { <span class="val-red">@_error</span> }
                    </div>
                </div>
            </div>
        </section>
    }
    else if (!SecretSvc.IsUnlocked)
    {
        @* ── Locked: unlock with the master password ─────────────────────────── *@
        <section class="atom-section-block secrets-form secrets-gate">
            <div class="atom-block-title">Locked</div>
            <div class="config-form">
                <div class="config-row">
                    <label class="config-label">Master password</label>
                    <input type="password" class="config-input config-input-wide" @bind="_pw1" @bind:event="oninput"
                           @onkeydown="@(e => { if (e.Key == "Enter") return Unlock(); return Task.CompletedTask; })" />
                </div>
                <div class="config-row">
                    <label class="config-label"></label>
                    <div>
                        <button class="btn-primary btn-sm" disabled="@(string.IsNullOrEmpty(_pw1))" @onclick="Unlock">Unlock</button>
                        @if (_error is not null) { <span class="val-red">@_error</span> }
                    </div>
                </div>
            </div>
        </section>
    }
    else if (_all is not null)
    {
        @* ── Unlocked: the vault ─────────────────────────────────────────────── *@
        @foreach (var group in _all.GroupBy(s => s.Project).OrderBy(g => g.Key))
        {
            <section class="atom-section-block secrets-group">
                <div class="atom-block-title">@group.Key</div>
                <table class="secrets-table">
                    <tbody>
                    @foreach (var s in group)
                    {
                        var sid = s.Id;
                        var shown = _reveal.Contains(sid);
                        <tr>
                            <td class="sec-label">
                                @s.Label
                                @if (!string.IsNullOrWhiteSpace(s.Notes))
                                {
                                    <div class="sec-notes">@s.Notes</div>
                                }
                            </td>
                            <td class="sec-value">
                                <code>@(shown ? s.Value : new string('•', Math.Min(12, Math.Max(6, s.Value.Length))))</code>
                            </td>
                            <td class="sec-actions">
                                <button class="btn-secondary btn-sm" @onclick="() => Toggle(sid)">@(shown ? "Hide" : "Show")</button>
                                <button class="btn-secondary btn-sm" @onclick="() => BeginEdit(s)">Edit</button>
                                <button class="btn-secondary btn-sm" @onclick="() => Delete(sid)">Delete</button>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </section>
        }

        @if (_all.Count == 0)
        {
            <div class="secrets-notice">No passwords stored yet.</div>
        }

        @* ── Add / Edit form ─────────────────────────────────────────────────── *@
        <section class="atom-section-block secrets-form">
            <div class="atom-block-title">@(_editId > 0 ? "Edit password" : "Add password")</div>
            <div class="config-form">
                <div class="config-row">
                    <label class="config-label">Project</label>
                    <input class="config-input" list="sec-projects" placeholder="e.g. DesignWorks" @bind="_project" />
                    <datalist id="sec-projects">
                        @foreach (var p in _all.Select(s => s.Project).Distinct().OrderBy(p => p))
                        {
                            <option value="@p" />
                        }
                    </datalist>
                </div>
                <div class="config-row">
                    <label class="config-label">Label</label>
                    <input class="config-input config-input-wide" placeholder="e.g. PostgreSQL — designworks user" @bind="_label" />
                </div>
                <div class="config-row">
                    <label class="config-label">Value</label>
                    <input class="config-input config-input-wide" placeholder="the password / secret" @bind="_value" />
                </div>
                <div class="config-row">
                    <label class="config-label">Notes</label>
                    <input class="config-input config-input-wide" placeholder="optional" @bind="_notes" />
                </div>
                <div class="config-row">
                    <label class="config-label"></label>
                    <div>
                        <button class="btn-primary btn-sm" disabled="@(!CanSave)" @onclick="Save">@(_editId > 0 ? "Update" : "Add")</button>
                        @if (_editId > 0)
                        {
                            <button class="btn-secondary btn-sm" @onclick="ClearForm">Cancel</button>
                        }
                        @if (_error is not null) { <span class="val-red">@_error</span> }
                    </div>
                </div>
            </div>
        </section>
    }
</div>

@code {
    List<Secret>? _all;
    readonly HashSet<int> _reveal = new();

    int _editId;
    string _project = "";
    string _label = "";
    string _value = "";
    string? _notes;
    string _pw1 = "";
    string _pw2 = "";
    string? _error;

    bool CanConfigure => _pw1.Length >= 6 && _pw1 == _pw2;
    bool CanSave => !string.IsNullOrWhiteSpace(_project)
                 && !string.IsNullOrWhiteSpace(_label)
                 && !string.IsNullOrWhiteSpace(_value);

    protected override async Task OnInitializedAsync()
    {
        if (SecretSvc.IsConfigured && SecretSvc.IsUnlocked) await Reload();
    }

    async Task Reload() => _all = await SecretSvc.AllAsync();

    async Task Configure()
    {
        _error = null;
        if (!CanConfigure) { _error = "Passwords must match and be at least 6 characters."; return; }
        await SecretSvc.ConfigureAsync(_pw1);
        _pw1 = _pw2 = "";
        await Reload();
    }

    async Task Unlock()
    {
        _error = null;
        if (!SecretSvc.TryUnlock(_pw1)) { _error = "Wrong password."; return; }
        _pw1 = "";
        await Reload();
    }

    void Lock()
    {
        SecretSvc.Lock();
        _all = null;
        _reveal.Clear();
        ClearForm();
    }

    void Toggle(int id)
    {
        if (!_reveal.Remove(id)) _reveal.Add(id);
    }

    void BeginEdit(Secret s)
    {
        _editId = s.Id;
        _project = s.Project;
        _label = s.Label;
        _value = s.Value;
        _notes = s.Notes;
        _error = null;
    }

    void ClearForm()
    {
        _editId = 0;
        _project = _label = _value = "";
        _notes = null;
        _error = null;
    }

    async Task Save()
    {
        if (!CanSave) { _error = "Project, label and value are required."; return; }
        await SecretSvc.UpsertAsync(_editId, _project, _label, _value, _notes);
        ClearForm();
        await Reload();
    }

    async Task Delete(int id)
    {
        await SecretSvc.DeleteAsync(id);
        _reveal.Remove(id);
        if (_editId == id) ClearForm();
        await Reload();
    }
}
