@page "/settings"
@using Tower.Core.Backup
@using Tower.Core.Settings
@using Tower.Core.State
@inject SettingsService SettingsSvc
@inject DropboxTokenService DropboxTokenSvc
@inject LiveState Live
@inject NavigationManager Navigation
@implements IAsyncDisposable

<PageTitle>Tower — Settings</PageTitle>

<div class="settings-page">

    <h1 class="page-title">Settings</h1>

    @* ── A) API Keys ──────────────────────────────────────────────────────────── *@
    <section class="settings-section">
        <div class="atom-section-block">
            <div class="atom-block-title">API Keys</div>
            <div class="config-form">

                @* ── Jellyfin ── *@
                <div class="config-row">
                    <label class="config-label">Jellyfin API Key</label>
                    <div class="config-control">
                        @if (SettingsSvc.IsConfigured("jellyfin.api_key") && !_jellyfinReplacing)
                        {
                            <div class="key-configured-row">
                                <span class="val-green configured-badge">&#10003; Configured</span>
                                <button class="btn-secondary btn-sm" @onclick="() => _jellyfinReplacing = true">Replace</button>
                            </div>
                        }
                        else
                        {
                            <div class="key-input-row">
                                <input type="password" class="config-input config-input-wide"
                                       placeholder="Paste new API key…"
                                       @bind="_jellyfinValue"
                                       @bind:event="oninput" />
                                <button class="btn btn-primary btn-sm" @onclick="SaveJellyfin">Save</button>
                                @if (SettingsSvc.IsConfigured("jellyfin.api_key"))
                                {
                                    <button class="btn-secondary btn-sm" @onclick="CancelJellyfin">Cancel</button>
                                }
                            </div>
                            @if (_jellyfinSaved)
                            {
                                <span class="save-confirm">Saved &#10003;</span>
                            }
                        }
                        <span class="config-hint">Used by the Jellyfin integration (play history, library stats).</span>
                    </div>
                </div>

                @* ── Dropbox App Key ── *@
                <div class="config-row">
                    <label class="config-label">Dropbox App Key</label>
                    <div class="config-control">
                        @if (SettingsSvc.IsConfigured("dropbox.app_key") && !_dropboxKeyReplacing)
                        {
                            <div class="key-configured-row">
                                <span class="val-green configured-badge">&#10003; Configured</span>
                                <button class="btn-secondary btn-sm" @onclick="() => _dropboxKeyReplacing = true">Replace</button>
                            </div>
                        }
                        else
                        {
                            <div class="key-input-row">
                                <input type="text" class="config-input config-input-wide"
                                       placeholder="App Key from Dropbox App Console…"
                                       @bind="_dropboxKeyValue" @bind:event="oninput" />
                                <button class="btn btn-primary btn-sm" @onclick="SaveDropboxKey">Save</button>
                                @if (SettingsSvc.IsConfigured("dropbox.app_key"))
                                {
                                    <button class="btn-secondary btn-sm" @onclick="CancelDropboxKey">Cancel</button>
                                }
                            </div>
                        }
                    </div>
                </div>

                @* ── Dropbox App Secret ── *@
                <div class="config-row">
                    <label class="config-label">Dropbox App Secret</label>
                    <div class="config-control">
                        @if (SettingsSvc.IsConfigured("dropbox.app_secret") && !_dropboxSecretReplacing)
                        {
                            <div class="key-configured-row">
                                <span class="val-green configured-badge">&#10003; Configured</span>
                                <button class="btn-secondary btn-sm" @onclick="() => _dropboxSecretReplacing = true">Replace</button>
                            </div>
                        }
                        else
                        {
                            <div class="key-input-row">
                                <input type="password" class="config-input config-input-wide"
                                       placeholder="App Secret from Dropbox App Console…"
                                       @bind="_dropboxSecretValue" @bind:event="oninput" />
                                <button class="btn btn-primary btn-sm" @onclick="SaveDropboxSecret">Save</button>
                                @if (SettingsSvc.IsConfigured("dropbox.app_secret"))
                                {
                                    <button class="btn-secondary btn-sm" @onclick="CancelDropboxSecret">Cancel</button>
                                }
                            </div>
                        }
                    </div>
                </div>

                @* ── Dropbox Connection ── *@
                <div class="config-row">
                    <label class="config-label">Dropbox Connection</label>
                    <div class="config-control">
                        @if (SettingsSvc.IsConfigured("dropbox.refresh_token"))
                        {
                            <div class="key-configured-row">
                                <span class="val-green configured-badge">&#10003; Connected</span>
                                <button class="btn-secondary btn-sm" @onclick="DisconnectDropbox">Disconnect</button>
                            </div>
                            @if (_dropboxConnectedMsg)
                            {
                                <span class="save-confirm">Authorized &#10003;</span>
                            }
                        }
                        else if (SettingsSvc.IsConfigured("dropbox.app_key") && SettingsSvc.IsConfigured("dropbox.app_secret"))
                        {
                            @if (_dropboxConnectError != null)
                            {
                                <div class="val-red" style="margin-bottom:0.4rem">&#10007; @_dropboxConnectError</div>
                            }

                            @* Step 1 — register redirect URI *@
                            <div class="config-hint" style="margin-bottom:0.5rem">
                                <strong>Step 1:</strong> In the <a href="https://www.dropbox.com/developers/apps" target="_blank">Dropbox App Console</a>,
                                add this Redirect URI: <code>@DropboxTokenService.RedirectUri</code>
                            </div>

                            @* Step 2 — open auth link *@
                            <div class="config-hint" style="margin-bottom:0.5rem">
                                <strong>Step 2:</strong>
                                <a class="btn btn-primary btn-sm" href="@_authUrl" target="_blank">Open Dropbox Authorization</a>
                                &nbsp; Log in and click Allow.
                            </div>

                            @* Step 3 — paste code *@
                            <div class="config-hint" style="margin-bottom:0.4rem">
                                <strong>Step 3:</strong> After authorizing, you'll be redirected to
                                <code>localhost:8888</code>. If that page loads, authorization is complete automatically.
                                If it fails (you accessed Tower remotely), copy the <code>code=…</code> value
                                from the browser URL bar and paste it here:
                            </div>
                            <div class="key-input-row">
                                <input type="text" class="config-input config-input-wide"
                                       placeholder="Paste authorization code…"
                                       @bind="_manualCode" @bind:event="oninput" />
                                <button class="btn btn-primary btn-sm"
                                        disabled="@(string.IsNullOrWhiteSpace(_manualCode) || _authorizing)"
                                        @onclick="CompleteAuthorizationAsync">
                                    @(_authorizing ? "Connecting…" : "Complete")
                                </button>
                            </div>
                        }
                        else
                        {
                            <span class="config-hint">Save App Key and App Secret above to enable authorization.</span>
                        }
                    </div>
                </div>

                @* ── Telegram ── *@
                <div class="config-row">
                    <label class="config-label">Telegram Bot Token</label>
                    <div class="config-control">
                        @if (SettingsSvc.IsConfigured("telegram.bot_token") && !_telegramReplacing)
                        {
                            <div class="key-configured-row">
                                <span class="val-green configured-badge">&#10003; Configured</span>
                                <button class="btn-secondary btn-sm" @onclick="() => _telegramReplacing = true">Replace</button>
                            </div>
                        }
                        else
                        {
                            <div class="key-input-row">
                                <input type="password" class="config-input config-input-wide"
                                       placeholder="Paste bot token…"
                                       @bind="_telegramValue"
                                       @bind:event="oninput" />
                                <button class="btn btn-primary btn-sm" @onclick="SaveTelegram">Save</button>
                                @if (SettingsSvc.IsConfigured("telegram.bot_token"))
                                {
                                    <button class="btn-secondary btn-sm" @onclick="CancelTelegram">Cancel</button>
                                }
                            </div>
                            @if (_telegramSaved)
                            {
                                <span class="save-confirm">Saved &#10003;</span>
                            }
                        }
                        <span class="config-hint">Used for Telegram notifications (wired in M3).</span>
                    </div>
                </div>

            </div>
        </div>
    </section>

    @* ── B) Backup ────────────────────────────────────────────────────────────── *@
    <section class="settings-section">
        <div class="atom-section-block">
            <div class="atom-block-title">Backup</div>
            <div class="config-form">

                <div class="config-row">
                    <label class="config-label" for="backup-schedule">Backup Schedule</label>
                    <div class="config-control">
                        <input type="time" id="backup-schedule"
                               class="config-input"
                               value="@_backupSchedule"
                               @oninput="e => _backupSchedule = e.Value?.ToString() ?? string.Empty" />
                        <span class="config-hint">Time-of-day to run automatic Dropbox backups (e.g. 02:00). Backup execution wired in M2.</span>
                    </div>
                </div>

                <div class="config-row">
                    <div class="config-label"></div>
                    <div class="config-control">
                        <button class="btn btn-primary" @onclick="SaveBackup">Save</button>
                        @if (_backupSaved)
                        {
                            <span class="save-confirm">Saved &#10003;</span>
                        }
                    </div>
                </div>

            </div>
        </div>
    </section>

    @* ── C) Storage / Sizes ───────────────────────────────────────────────────── *@
    <section class="settings-section">
        <div class="atom-section-block">
            <div class="atom-block-title">Storage Sizes</div>

            <table class="atom-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Path</th>
                        <th>Size</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @{ var sizes = Live.Sizes; }
                    @foreach (var item in sizes)
                    {
                        <tr>
                            <td><strong>@item.Name</strong></td>
                            <td class="mono text-muted">@item.Path</td>
                            <td>@(item.Exists ? Fmt.Bytes(item.Bytes) : "—")</td>
                            <td>
                                @if (item.Exists)
                                {
                                    <span class="val-green">&#10003;</span>
                                }
                                else
                                {
                                    <span class="val-red">Missing</span>
                                }
                            </td>
                        </tr>
                    }
                    @if (!sizes.Any())
                    {
                        <tr><td colspan="4" class="text-muted">Collecting… (refreshes every 5 min)</td></tr>
                    }
                </tbody>
            </table>

            @* ── Log retention ── *@
            <div style="margin-top:1.2rem;">
                <div class="atom-block-title" style="margin-top:0.5rem;">Log Retention</div>
                <div class="config-form">
                    <div class="config-row">
                        <label class="config-label" for="log-retention">Retention (days)</label>
                        <div class="config-control">
                            <input type="number" id="log-retention" min="1" max="365"
                                   class="config-input"
                                   value="@_logRetentionDays"
                                   @oninput="e => _logRetentionDays = e.Value?.ToString() ?? string.Empty" />
                            <span class="config-hint">Number of days to keep log files. Pruning wired in a future milestone.</span>
                        </div>
                    </div>
                    <div class="config-row">
                        <div class="config-label"></div>
                        <div class="config-control">
                            <button class="btn btn-primary" @onclick="SaveLogRetention">Save</button>
                            @if (_logRetentionSaved)
                            {
                                <span class="save-confirm">Saved &#10003;</span>
                            }
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </section>

</div>

@code {
    // ── Jellyfin ──────────────────────────────────────────────────────────────
    private string _jellyfinValue    = "";
    private bool   _jellyfinReplacing = false;
    private bool   _jellyfinSaved    = false;

    // ── Dropbox ───────────────────────────────────────────────────────────────
    private string _dropboxKeyValue        = "";
    private bool   _dropboxKeyReplacing    = false;
    private string _dropboxSecretValue     = "";
    private bool   _dropboxSecretReplacing = false;
    private bool   _dropboxConnectedMsg    = false;
    private string? _dropboxConnectError   = null;
    private string _authUrl                = "";
    private string _manualCode             = "";
    private bool   _authorizing            = false;

    // ── Telegram ──────────────────────────────────────────────────────────────
    private string _telegramValue    = "";
    private bool   _telegramReplacing = false;
    private bool   _telegramSaved    = false;

    // ── Backup ────────────────────────────────────────────────────────────────
    private string _backupSchedule = "";
    private bool   _backupSaved    = false;

    // ── Log retention ─────────────────────────────────────────────────────────
    private string _logRetentionDays  = "30";
    private bool   _logRetentionSaved = false;

    // ── Timer for auto-refresh ────────────────────────────────────────────────
    private System.Threading.Timer? _timer;
    private bool _disposed = false;

    protected override void OnInitialized()
    {
        _backupSchedule   = SettingsSvc.Get("backup.schedule") ?? "";
        _logRetentionDays = SettingsSvc.Get("log.retention_days") ?? "30";

        var appKey = SettingsSvc.Get("dropbox.app_key");
        if (!string.IsNullOrEmpty(appKey))
            _authUrl = DropboxTokenSvc.BuildAuthUrl(appKey);

        // Check if we just returned from Dropbox OAuth (localhost auto-redirect path)
        var uri = new Uri(Navigation.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        if (query["dropbox"] == "connected")
        {
            _dropboxConnectedMsg = true;
        }
        else if (query["dropbox_error"] is { } err)
        {
            _dropboxConnectError = err;
        }

        // Refresh the sizes table every 10 s
        _timer = new System.Threading.Timer(_ =>
        {
            if (!_disposed)
                InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(10), TimeSpan.FromSeconds(10));
    }

    // ── Jellyfin ──────────────────────────────────────────────────────────────

    private void CancelJellyfin()
    {
        _jellyfinReplacing = false;
        _jellyfinValue     = "";
    }

    private async Task SaveJellyfin()
    {
        var val = _jellyfinValue.Trim();
        if (string.IsNullOrWhiteSpace(val)) return;

        SettingsSvc.Set("jellyfin.api_key", val);
        _jellyfinValue    = "";
        _jellyfinReplacing = false;
        _jellyfinSaved    = true;
        StateHasChanged();

        await Task.Delay(2500);
        if (!_disposed) { _jellyfinSaved = false; await InvokeAsync(StateHasChanged); }
    }

    // ── Dropbox ───────────────────────────────────────────────────────────────

    private void CancelDropboxKey()   { _dropboxKeyReplacing   = false; _dropboxKeyValue    = ""; }
    private void CancelDropboxSecret() { _dropboxSecretReplacing = false; _dropboxSecretValue = ""; }

    private async Task SaveDropboxKey()
    {
        var val = _dropboxKeyValue.Trim();
        if (string.IsNullOrWhiteSpace(val)) return;
        SettingsSvc.Set("dropbox.app_key", val);
        _authUrl            = DropboxTokenSvc.BuildAuthUrl(val);
        _dropboxKeyValue    = "";
        _dropboxKeyReplacing = false;
        StateHasChanged();
        await Task.Delay(100);
    }

    private async Task SaveDropboxSecret()
    {
        var val = _dropboxSecretValue.Trim();
        if (string.IsNullOrWhiteSpace(val)) return;
        SettingsSvc.Set("dropbox.app_secret", val);
        _dropboxSecretValue    = "";
        _dropboxSecretReplacing = false;
        StateHasChanged();
        await Task.Delay(100);
    }

    private async Task CompleteAuthorizationAsync()
    {
        var code = _manualCode.Trim();
        if (string.IsNullOrEmpty(code)) return;

        _authorizing        = true;
        _dropboxConnectError = null;
        StateHasChanged();

        var (ok, err) = await DropboxTokenSvc.ExchangeCodeAsync(code);

        _authorizing = false;
        if (ok)
        {
            _dropboxConnectedMsg = true;
            _manualCode          = "";
        }
        else
        {
            _dropboxConnectError = err;
        }
        StateHasChanged();
    }

    private void DisconnectDropbox()
    {
        DropboxTokenSvc.Disconnect();
        StateHasChanged();
    }

    // ── Telegram ──────────────────────────────────────────────────────────────

    private void CancelTelegram()
    {
        _telegramReplacing = false;
        _telegramValue     = "";
    }

    private async Task SaveTelegram()
    {
        var val = _telegramValue.Trim();
        if (string.IsNullOrWhiteSpace(val)) return;

        SettingsSvc.Set("telegram.bot_token", val);
        _telegramValue    = "";
        _telegramReplacing = false;
        _telegramSaved    = true;
        StateHasChanged();

        await Task.Delay(2500);
        if (!_disposed) { _telegramSaved = false; await InvokeAsync(StateHasChanged); }
    }

    // ── Backup ────────────────────────────────────────────────────────────────

    private async Task SaveBackup()
    {
        SettingsSvc.Set("backup.schedule",
            string.IsNullOrWhiteSpace(_backupSchedule) ? null : _backupSchedule.Trim());
        _backupSaved = true;
        StateHasChanged();

        await Task.Delay(2500);
        if (!_disposed) { _backupSaved = false; await InvokeAsync(StateHasChanged); }
    }

    // ── Log retention ─────────────────────────────────────────────────────────

    private async Task SaveLogRetention()
    {
        SettingsSvc.Set("log.retention_days",
            string.IsNullOrWhiteSpace(_logRetentionDays) ? "30" : _logRetentionDays.Trim());
        _logRetentionSaved = true;
        StateHasChanged();

        await Task.Delay(2500);
        if (!_disposed) { _logRetentionSaved = false; await InvokeAsync(StateHasChanged); }
    }

    // ── Dispose ───────────────────────────────────────────────────────────────

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        if (_timer != null)
            await _timer.DisposeAsync();
    }
}
