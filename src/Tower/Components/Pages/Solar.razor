@page "/solar"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Tower.Core.Data
@using Tower.Core.Models
@using Tower.Core.Settings
@using Tower.Core.Solar
@using Tower.Core.Gmail
@using Tower.Core.Workers
@using Microsoft.Extensions.DependencyInjection
@inject IServiceScopeFactory ScopeFactory
@inject SettingsService Settings
@inject SolaxClient Solax
@inject GmailReader Reader
@inject SolarMailWorker Mail

<PageTitle>Tower — Solar</PageTitle>

<div class="solar-page">

    <h1 class="page-title">Solar</h1>

    @* ── 1. Live Tiles ─────────────────────────────────────────────────────── *@
    <section class="solar-section">
        <h2 class="section-title">Live</h2>

        @if (_latest is { } s)
        {
            <div class="atom-cards-grid">
                <div class="atom-card">
                    <div class="atom-card-title">AC Power</div>
                    <div class="atom-big-value">@s.AcPower.ToString("0") W</div>
                </div>
                <div class="atom-card">
                    <div class="atom-card-title">Battery</div>
                    <div class="atom-big-value">@s.Soc.ToString("0")%</div>
                </div>
                <div class="atom-card">
                    <div class="atom-card-title">Today</div>
                    <div class="atom-big-value">@s.YieldToday.ToString("0.0") kWh</div>
                </div>
                <div class="atom-card">
                    <div class="atom-card-title">Grid</div>
                    <div class="atom-big-value">@s.FeedInPower.ToString("0") W</div>
                </div>
                <div class="atom-card">
                    <div class="atom-card-title">Total</div>
                    <div class="atom-big-value">@s.YieldTotal.ToString("0") kWh</div>
                </div>
                <div class="atom-card">
                    <div class="atom-card-title">Status</div>
                    <div class="atom-big-value">@(s.InverterStatus ?? "—")</div>
                </div>
                <div class="atom-card">
                    <div class="atom-card-title">Alarms</div>
                    <div class="atom-big-value @(_alarms > 0 ? "val-red" : "val-green")">@_alarms</div>
                </div>
            </div>
        }
        else
        {
            <div class="solar-notice solar-notice-info">No live data yet. Configure SolaX below.</div>
        }
    </section>

    @* ── 2. Charts ─────────────────────────────────────────────────────────── *@
    <section class="solar-section">
        <h2 class="section-title">Power today</h2>
        <div class="atom-card">
            <Sparkline Data="_todayPower" Width="640" Height="140" />
        </div>
    </section>

    <section class="solar-section">
        <h2 class="section-title">Battery SOC today</h2>
        <div class="atom-card">
            <Sparkline Data="_todaySoc" Width="640" Height="140" Color="#3fb950" FillColor="rgba(63,185,80,0.12)" />
        </div>
    </section>

    @* ── 3. Sunlight vs yield + maintenance ─────────────────────────────────── *@
    <section class="solar-section">
        <h2 class="section-title">Sunlight vs yield</h2>

        @if (_maintMsg != null)
        {
            <div class="solar-notice @(_maintAlert ? "solar-notice-alert" : "solar-notice-ok")">@_maintMsg</div>
        }

        <div class="date-range">
            <label>From <input type="date" value="@_from.ToString("yyyy-MM-dd")" @onchange="OnFromChanged" /></label>
            <label>To <input type="date" value="@_to.ToString("yyyy-MM-dd")" @onchange="OnToChanged" /></label>
            <button class="btn btn-sm" @onclick="ResetRange">Last 30 days</button>
        </div>

        <div class="atom-card">
            <DualLineChart Labels="_dailyLabels"
                           Left="_dailyYield" LeftName="Daily yield" LeftUnit="kWh" LeftColor="#e3b341"
                           Right="_dailyIrr" RightName="Irradiance" RightUnit="MJ/m²" RightColor="#58a6ff"
                           Markers="_dailyAlarms" />
            @if (_dailyYield.Length > 1)
            {
                <div class="mono" style="margin-top:0.4rem;color:var(--text)">
                    latest @_dailyYield[^1].ToString("0.0") kWh
                    · max @_dailyYield.Max().ToString("0.0") kWh
                    @if (_alarmTotal > 0) { <span> · @_alarmTotal alarm(s) in window</span> }
                </div>
            }
        </div>
    </section>

    @* ── 3a. Weekly avg irradiance vs weekly yield ───────────────────────────── *@
    <section class="solar-section">
        <h2 class="section-title">Weekly: avg irradiance vs yield</h2>
        <div class="atom-card">
            <DualLineChart Labels="_weeklyLabels"
                           Left="_weeklyYield" LeftName="Weekly yield" LeftUnit="kWh" LeftColor="#3fb950"
                           Right="_weeklyIrr" RightName="Avg irradiance" RightUnit="MJ/m²" RightColor="#58a6ff" />
        </div>
    </section>

    @* ── 3b. Monthly yield trend ─────────────────────────────────────────────── *@
    <section class="solar-section">
        <h2 class="section-title">Monthly yield trend</h2>
        <div class="atom-card">
            @if (_monthly.Count > 1)
            {
                <Sparkline Data="_monthlySeries" Width="640" Height="160" Color="#3fb950" FillColor="rgba(63,185,80,0.12)" />
                <div class="text-muted mono" style="margin-top:0.4rem;">
                    @_monthly.First().PeriodEnd.ToString("MMM yyyy") – @_monthly.Last().PeriodEnd.ToString("MMM yyyy")
                    · latest @_monthly.Last().PeriodYieldKWh.ToString("0.0") kWh
                    · max @_monthly.Max(m => m.PeriodYieldKWh).ToString("0.0") kWh
                </div>
            }
            else
            {
                <div class="solar-notice solar-notice-idle">Need at least two monthly reports for a trend.</div>
            }
        </div>
    </section>

    @* ── 4. Reports ────────────────────────────────────────────────────────── *@
    <section class="solar-section">
        <h2 class="section-title">Reports</h2>
        <div class="config-row" style="margin-bottom:0.75rem;">
            <button class="btn btn-primary btn-sm" @onclick="ImportNow" disabled="@_importing">
                @(_importing ? "Importing…" : "Import reports now")
            </button>
            @if (_importMsg != null) { <span style="margin-left:0.75rem;">@_importMsg</span> }
        </div>
        <p class="config-hint">Reports auto-import every 12 h; imported emails are moved to Gmail Trash.</p>
        <div class="pills">
            <button class="@Tab(SolarReportType.Daily)" @onclick="() => SetTab(SolarReportType.Daily)">Daily</button>
            <button class="@Tab(SolarReportType.Weekly)" @onclick="() => SetTab(SolarReportType.Weekly)">Weekly</button>
            <button class="@Tab(SolarReportType.Monthly)" @onclick="() => SetTab(SolarReportType.Monthly)">Monthly</button>
        </div>
        <table class="atom-table">
            <thead>
                <tr><th>Period</th><th>Yield kWh</th><th>Earnings LKR</th><th>CO₂ t</th><th>Alarms</th></tr>
            </thead>
            <tbody>
                @foreach (var r in _reports.Where(r => r.ReportType == _tab).OrderByDescending(r => r.PeriodEnd))
                {
                    <tr>
                        <td>@r.PeriodStart.ToString("yyyy-MM-dd")@(r.PeriodStart != r.PeriodEnd ? " – " + r.PeriodEnd.ToString("MM-dd") : "")</td>
                        <td>@r.PeriodYieldKWh.ToString("0.0")</td>
                        <td>@r.PeriodEarningsLkr.ToString("N2")</td>
                        <td>@r.Co2SavedTons.ToString("0.0")</td>
                        <td>@r.AlarmQuantity</td>
                    </tr>
                }
                @if (!_reports.Any(r => r.ReportType == _tab))
                {
                    <tr><td colspan="5" class="text-muted">No @(_tab.ToString().ToLower()) reports yet.</td></tr>
                }
            </tbody>
        </table>
    </section>

    @* ── 5. Configuration ──────────────────────────────────────────────────── *@
    <section class="atom-section-block">
        <div class="atom-block-title">SolaX</div>
        <div class="config-form">
            <div class="config-row">
                <label class="config-label">Token ID</label>
                <div class="config-control">
                    <input type="text" class="config-input config-input-wide" @bind="_tokenId" @bind:event="oninput" />
                </div>
            </div>
            <div class="config-row">
                <label class="config-label">Inverter SN</label>
                <div class="config-control">
                    <input type="text" class="config-input config-input-wide" @bind="_sn" @bind:event="oninput" />
                </div>
            </div>
            <div class="config-row">
                <label class="config-label"></label>
                <div class="config-control">
                    <div class="solar-btn-row">
                        <button class="btn btn-primary btn-sm" @onclick="SaveSolax">Save</button>
                        <button class="btn-secondary btn-sm" @onclick="TestSolax">Test</button>
                    </div>
                    @if (_testMsg != null)
                    {
                        <span class="save-confirm">@_testMsg</span>
                    }
                </div>
            </div>
        </div>
    </section>

    <section class="atom-section-block">
        <div class="atom-block-title">Gmail Reports</div>
        <div class="config-form">
            <div class="config-row">
                <label class="config-label">Label</label>
                <div class="config-control">
                    <select class="config-input config-input-wide" @bind="_labelId">
                        <option value="">— none —</option>
                        @foreach (var l in _labels)
                        {
                            <option value="@l.Id">@l.Name</option>
                        }
                    </select>
                </div>
            </div>
            <div class="config-row">
                <label class="config-label"></label>
                <div class="config-control">
                    <button class="btn btn-primary btn-sm" @onclick="SaveLabel">Save label</button>
                </div>
            </div>
        </div>
    </section>

</div>

@code {
    private SolarSnapshot? _latest;
    private int _alarms;
    private double[] _todayPower = [], _todaySoc = [];
    private List<SolarReport> _allDaily = new(), _monthly = new(), _reports = new();
    private double[] _monthlySeries = [];
    private Dictionary<DateTime, double> _weatherDict = new();
    private Dictionary<DateTime, int> _alarmsByDate = new();
    private DateTime _from, _to;
    // daily chart series
    private List<string> _dailyLabels = new();
    private double[] _dailyYield = [], _dailyIrr = [];
    private int[] _dailyAlarms = [];
    private int _alarmTotal;
    // weekly chart series
    private List<string> _weeklyLabels = new();
    private double[] _weeklyYield = [], _weeklyIrr = [];
    private bool _maintAlert;
    private string? _maintMsg;
    private SolarReportType _tab = SolarReportType.Daily;
    private string _tokenId = "", _sn = "", _labelId = "";
    private string? _testMsg;
    private bool _importing;
    private string? _importMsg;
    private List<(string Id, string Name)> _labels = new();
    private static readonly System.Globalization.CultureInfo Inv = System.Globalization.CultureInfo.InvariantCulture;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();

        _tokenId = Settings.Get("solax.token_id") ?? "";
        _sn = Settings.Get("solax.sn") ?? "";
        _labelId = Settings.Get("gmail.label_id") ?? "";
        try { _labels = await Reader.ListLabelsAsync(); } catch { /* gmail not connected yet */ }
    }

    private async Task LoadDataAsync()
    {
        using var scope = ScopeFactory.CreateScope();
        var db = scope.ServiceProvider.GetRequiredService<TowerDbContext>();
        _latest = await db.SolarSnapshots.OrderByDescending(x => x.CapturedAt).FirstOrDefaultAsync();

        var since = DateTime.UtcNow.Date;
        var today = await db.SolarSnapshots.Where(x => x.CapturedAt >= since)
            .OrderBy(x => x.CapturedAt).ToListAsync();
        _todayPower = today.Select(x => x.AcPower).ToArray();
        _todaySoc = today.Select(x => x.Soc).ToArray();

        _reports = await db.SolarReports.ToListAsync();
        _allDaily = _reports.Where(r => r.ReportType == SolarReportType.Daily)
            .OrderBy(r => r.PeriodEnd).ToList();
        _monthly = _reports.Where(r => r.ReportType == SolarReportType.Monthly).OrderBy(r => r.PeriodEnd).ToList();
        _monthlySeries = _monthly.Select(m => m.PeriodYieldKWh).ToArray();
        _alarms = _reports.OrderByDescending(r => r.PeriodEnd).FirstOrDefault()?.AlarmQuantity ?? 0;

        _weatherDict = (await db.SolarWeather.ToListAsync()).ToDictionary(w => w.Date.Date, w => w.ShortwaveRadiationMJ);
        _alarmsByDate = (await db.SolarAlarms.ToListAsync())
            .GroupBy(a => a.AlarmDate.Date).ToDictionary(g => g.Key, g => g.Count());

        // Default the range to the last 30 days on first load; keep the user's pick on refresh.
        if (_to == default)
        {
            var end = _allDaily.Count > 0 ? _allDaily[^1].PeriodEnd.Date : DateTime.UtcNow.Date;
            _to = end;
            _from = end.AddDays(-30);
        }

        BuildCharts();
        ComputeMaintenance();
    }

    private void BuildCharts()
    {
        var d = _allDaily.Where(x => x.PeriodEnd.Date >= _from.Date && x.PeriodEnd.Date <= _to.Date)
            .OrderBy(x => x.PeriodEnd).ToList();

        _dailyLabels = d.Select(x => x.PeriodEnd.ToString("MMM d")).ToList();
        _dailyYield = d.Select(x => x.PeriodYieldKWh).ToArray();
        _dailyIrr = d.Select(x => _weatherDict.GetValueOrDefault(x.PeriodEnd.Date)).ToArray();
        _dailyAlarms = d.Select(x => _alarmsByDate.GetValueOrDefault(x.PeriodEnd.Date)).ToArray();
        _alarmTotal = _dailyAlarms.Sum();

        // Weekly (Mon-start) aggregation over the selected range: yield summed, irradiance averaged.
        var weeks = d.GroupBy(x => StartOfWeek(x.PeriodEnd.Date)).OrderBy(g => g.Key).ToList();
        _weeklyLabels = weeks.Select(g => g.Key.ToString("MMM d")).ToList();
        _weeklyYield = weeks.Select(g => g.Sum(x => x.PeriodYieldKWh)).ToArray();
        _weeklyIrr = weeks.Select(g =>
            g.Select(x => _weatherDict.GetValueOrDefault(x.PeriodEnd.Date)).Where(v => v > 0).DefaultIfEmpty(0).Average()).ToArray();
    }

    private static DateTime StartOfWeek(DateTime d)
    {
        int diff = ((int)d.DayOfWeek + 6) % 7; // Monday = 0
        return d.AddDays(-diff);
    }

    private void OnFromChanged(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var d)) { _from = d.Date; BuildCharts(); }
    }

    private void OnToChanged(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var d)) { _to = d.Date; BuildCharts(); }
    }

    private void ResetRange()
    {
        var end = _allDaily.Count > 0 ? _allDaily[^1].PeriodEnd.Date : DateTime.UtcNow.Date;
        _to = end; _from = end.AddDays(-30);
        BuildCharts();
    }

    // Flag maintenance when recent output is low relative to sunlight, or alarms fired recently.
    // Performance ratio PR = yield / irradiance; compare last-7-day mean to the median baseline.
    private void ComputeMaintenance()
    {
        _maintAlert = false; _maintMsg = null;

        var recentAlarms = _alarmsByDate.Where(kv => kv.Key >= DateTime.UtcNow.Date.AddDays(-7)).Sum(kv => kv.Value);

        var prs = _allDaily
            .Select(d => new { d.PeriodEnd, Rad = _weatherDict.GetValueOrDefault(d.PeriodEnd.Date), d.PeriodYieldKWh })
            .Where(x => x.Rad > 0)
            .Select(x => new { x.PeriodEnd, Pr = x.PeriodYieldKWh / x.Rad })
            .OrderBy(x => x.PeriodEnd)
            .ToList();

        double threshold = 0.80;
        if (double.TryParse(Settings.Get("solar.maint.threshold"), System.Globalization.NumberStyles.Float, Inv, out var t) && t > 0)
            threshold = t;

        if (prs.Count >= 14)
        {
            var baseline = Median(prs.Select(p => p.Pr).ToList());
            var recent = prs.TakeLast(7).Average(p => p.Pr);
            var ratio = baseline > 0 ? recent / baseline : 1;
            if (ratio < threshold)
            {
                _maintAlert = true;
                _maintMsg = $"⚠ Maintenance likely — last-7-day output is {(1 - ratio) * 100:0}% below what the sunlight received predicts. Check panels for soiling, shading, or a faulty string.";
            }
        }

        if (recentAlarms > 0)
        {
            _maintAlert = true;
            _maintMsg = (_maintMsg == null ? "" : _maintMsg + " ")
                + $"⚠ {recentAlarms} abnormal-power alarm(s) from the inverter in the last 7 days.";
        }

        if (!_maintAlert && prs.Count >= 14)
            _maintMsg = "✓ Performance normal — output tracks the available sunlight, no recent alarms.";
    }

    private static double Median(List<double> xs)
    {
        if (xs.Count == 0) return 0;
        var s = xs.OrderBy(v => v).ToList();
        int m = s.Count / 2;
        return s.Count % 2 == 1 ? s[m] : (s[m - 1] + s[m]) / 2.0;
    }

    private async Task ImportNow()
    {
        _importing = true;
        _importMsg = null;
        try
        {
            var n = await Mail.RunOnceAsync();
            await LoadDataAsync();
            var err = Settings.Get("solar.mail.last_error");
            _importMsg = $"Imported {n} report(s)." + (string.IsNullOrEmpty(err) ? "" : $" Last error: {err}");
        }
        catch (Exception ex) { _importMsg = "Import failed: " + ex.Message; }
        finally { _importing = false; }
    }

    private string Tab(SolarReportType t) => t == _tab ? "pill active" : "pill";
    private void SetTab(SolarReportType t) => _tab = t;
    private void SaveSolax() { Settings.Set("solax.token_id", _tokenId.Trim()); Settings.Set("solax.sn", _sn.Trim()); }
    private void SaveLabel() => Settings.Set("gmail.label_id", _labelId);

    private async Task TestSolax()
    {
        var snap = await Solax.GetRealtimeAsync(_tokenId.Trim(), _sn.Trim());
        _testMsg = snap != null ? $"OK — {snap.AcPower:0} W now" : "No data / invalid token or SN";
    }
}
