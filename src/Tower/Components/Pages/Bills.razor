@page "/bills"
@rendermode InteractiveServer
@using Tower.Core.Bills
@using Tower.Core.Data
@using Tower.Core.Gmail
@using Tower.Core.Settings
@using Tower.Core.Workers
@inject BillMailWorker BillMail
@inject GmailTokenService Tokens
@inject SettingsService SettingsSvc
@inject TowerDbContext Db
@implements IDisposable

<PageTitle>Tower — Bill Importer</PageTitle>

<div class="gmail-page">

    <h1 class="page-title">Bill Importer</h1>

    @if (BillMail.IsRunning)
    {
        <div style="background:#0b7285;color:#fff;padding:10px 14px;border-radius:6px;
                    margin-bottom:14px;display:flex;gap:10px;align-items:center;">
            <span style="font-size:1.1em;">⏳</span>
            <span>
                <strong>Importing…</strong>
                scanned @BillMail.RunScanned@(BillMail.RunTotal > 0 ? $" / {BillMail.RunTotal}" : ""),
                @BillMail.RunImported added
                @if (BillMail.RunStartedAt is { } t)
                {
                    <span style="opacity:.8;"> — started @t.ToLocalTime().ToString("HH:mm:ss")</span>
                }
            </span>
        </div>
    }

    @if (!Tokens.IsConnected)
    {
        <section class="atom-section-block">
            <div class="config-hint" style="padding:8px 0;color:#b00020;">
                &#9888; Gmail isn't connected — imports are paused. <a href="/gmail">Connect Gmail</a>.
            </div>
        </section>
    }

    @* ── Schedule & run ─────────────────────────────────────────────────────── *@
    <section class="atom-section-block">
        <div class="atom-block-title">Schedule &amp; Run</div>
        <div class="config-form">
            <div class="config-row">
                <label class="config-label">Run every</label>
                <div class="config-control">
                    <input type="number" min="1" class="config-input" style="width:80px" @bind="_interval" /> hours
                    <button class="btn-secondary btn-sm" @onclick="SaveInterval">Save</button>
                    @if (_intervalSaved)
                    {
                        <span class="save-confirm">Saved — applies from next cycle.</span>
                    }
                </div>
            </div>
            <div class="config-row">
                <label class="config-label">Bills label</label>
                <div class="config-control">@_labelName</div>
            </div>
            <div class="config-row">
                <label class="config-label">Last run</label>
                <div class="config-control">@(_lastRun ?? "never")</div>
            </div>
            <div class="config-row">
                <label class="config-label">Imported (last run)</label>
                <div class="config-control">@_lastCount</div>
            </div>
            <div class="config-row">
                <label class="config-label">Error</label>
                <div class="config-control">@(_lastError ?? "none")</div>
            </div>
            <div class="config-row">
                <label class="config-label"></label>
                <div class="config-control">
                    <button class="btn btn-primary btn-sm" disabled="@(BillMail.IsRunning || !Tokens.IsConnected)" @onclick="ImportNow">
                        @(BillMail.IsRunning ? "Importing…" : "Import bills now")
                    </button>
                </div>
            </div>
        </div>
    </section>

    @* ── Loaded profiles ────────────────────────────────────────────────────── *@
    <section class="atom-section-block">
        <div class="atom-block-title">Loaded Profiles (@BillProfiles.All.Count)</div>
        <p class="config-hint">
            Emails in the Bills label are matched against these rules in order — first match wins;
            unmatched emails are left untouched.
        </p>
        <div class="config-row">
            <label class="config-label">Source</label>
            <div class="config-control">
                <code>@(BillProfiles.SourcePath ?? "built-in defaults")</code>
                @if (BillProfiles.LoadedAt is { } loadedAt)
                {
                    <span style="opacity:.7;"> — loaded @loadedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</span>
                }
            </div>
        </div>
        <div class="config-row">
            <label class="config-label"></label>
            <div class="config-control">
                <button class="btn-secondary btn-sm" @onclick="ReloadProfiles">Reload profiles</button>
                <span class="config-hint" style="margin-left:8px;">
                    Edit <code>bill-profiles.xml</code> in the app directory, then reload — no rebuild needed.
                </span>
            </div>
        </div>
        @if (_reloadMsg is { } msg)
        {
            <div class="config-row">
                <label class="config-label"></label>
                <div class="config-control" style="color:@(BillProfiles.LoadError is null ? "#0b7285" : "#b00020");">@msg</div>
            </div>
        }
        <table class="atom-table">
            <thead>
                <tr>
                    @SortHeader(Sort.Name, "Profile", null)
                    @SortHeader(Sort.From, "From contains", null)
                    <th>Matching rules</th>
                    @SortHeader(Sort.Category, "Category", null)
                    @SortHeader(Sort.Currency, "Cur", null)
                    @SortHeader(Sort.Count, "#", "text-align:right;")
                    @SortHeader(Sort.Value, "Value", "text-align:right;")
                </tr>
            </thead>
            <tbody>
                @foreach (var p in SortedProfiles())
                {
                    var (count, total) = Stat(p.Name);
                    <tr class="profile-row">
                        <td>
                            <div class="profile-name">@p.Name</div>
                            @if (Flags(p) is { Count: > 0 } flags)
                            {
                                <div class="flag-row">
                                    @foreach (var f in flags)
                                    {
                                        <span class="flag" title="@f.Help">@f.Label</span>
                                    }
                                </div>
                            }
                        </td>
                        <td class="mono">@p.FromContains</td>
                        <td>
                            <div class="rule-grid">
                                <span class="rule-key">subject</span>
                                <span class="rule-val">@p.SubjectRegex</span>

                                @for (var i = 0; i < p.AmountRegexes.Length; i++)
                                {
                                    <span class="rule-key">@(i == 0 ? "amount" : $"else {i}")</span>
                                    <span class="rule-val @(i == 0 ? "" : "alt")">@p.AmountRegexes[i]</span>
                                }

                                @if (p.CategoryRules is { } cr)
                                {
                                    @foreach (var t in cr.Tokens)
                                    {
                                        <span class="rule-key">token</span>
                                        <span class="rule-val alt">@t</span>
                                    }
                                    <span class="rule-key">routes to</span>
                                    <span class="rule-val alt">
                                        @string.Join("   ", cr.When.Select(w => $"{w.Prefix}… → {w.Category}"))
                                    </span>
                                }
                            </div>
                        </td>
                        <td>@p.Category</td>
                        <td>@p.Currency</td>
                        <td class="num" style="text-align:right;">@(count == 0 ? "—" : count.ToString("N0"))</td>
                        <td class="num" style="text-align:right; white-space:nowrap;">
                            @(count == 0 ? "—" : $"{total:N2} {p.Currency}")
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <p class="config-hint">
            Profiles live in <code>bill-profiles.xml</code> in the app directory. Adding a bill type
            is a few lines there followed by <em>Reload profiles</em> — no rebuild, no redeploy. The
            schema is documented at the top of the file, and
            <code>bill-profiles.default.xml</code> beside it is a read-only reference copy rewritten
            on every restart. A malformed file is rejected whole, leaving the running profiles in place.
        </p>
    </section>

</div>

@code {
    private int _interval = 6;
    private bool _intervalSaved;
    private string? _lastRun, _lastError, _labelName;
    private int _lastCount;
    private Dictionary<string, (int, decimal)> _stats = new();
    private System.Threading.Timer? _timer;

    protected override void OnInitialized()
    {
        // _interval seeds the editable field once; the timer must not clobber it while the user types.
        if (int.TryParse(SettingsSvc.Get("bills.interval_hours"), out var bi) && bi > 0) _interval = bi;
        LoadStatus();
        // While the page is open, refresh live sweep progress + settled counts every 2s.
        _timer = new System.Threading.Timer(_ =>
        {
            try { _ = InvokeAsync(() => { LoadStatus(); StateHasChanged(); }); }
            catch { /* circuit gone */ }
        }, null, 2000, 2000);
    }

    private void LoadStatus()
    {
        _labelName = SettingsSvc.Get("bills.label_name") ?? "Bills";
        _lastRun = SettingsSvc.Get("bills.mail.last_run");
        _lastError = SettingsSvc.Get("bills.mail.last_error");
        int.TryParse(SettingsSvc.Get("bills.mail.last_count"), out _lastCount);
        // decimal is stored as TEXT in SQLite, so aggregate client-side (row count is small).
        _stats = Db.ImportedBills
            .Where(b => b.TransactionId != null)
            .Select(b => new { b.Profile, b.Amount })
            .AsEnumerable()
            .GroupBy(r => r.Profile)
            .ToDictionary(g => g.Key, g => (g.Count(), g.Sum(x => x.Amount)));
    }

    private void SaveInterval()
    {
        if (_interval < 1) _interval = 1;
        SettingsSvc.Set("bills.interval_hours", _interval.ToString());
        _intervalSaved = true;
    }

    private string? _reloadMsg;

    private enum Sort { Name, From, Category, Currency, Count, Value }

    // Busiest profiles first — that's the useful default when scanning for what is and isn't working.
    private Sort _sort = Sort.Count;
    private bool _desc = true;

    private void SortBy(Sort col)
    {
        // Re-clicking a column flips it; a new column starts descending for the numbers (biggest
        // first) and ascending for the text ones (A-Z), which is what each is usually wanted as.
        if (_sort == col) _desc = !_desc;
        else (_sort, _desc) = (col, col is Sort.Count or Sort.Value);
    }

    private (int Count, decimal Total) Stat(string profile) =>
        _stats.TryGetValue(profile, out var v) ? v : (0, 0m);

    private IEnumerable<BillProfile> SortedProfiles()
    {
        // Value sorts on the raw number across currencies — the cell always shows the unit, so a
        // USD row sitting among LKR rows reads correctly rather than pretending to be comparable.
        Func<BillProfile, IComparable> key = _sort switch
        {
            Sort.From => p => p.FromContains,
            Sort.Category => p => p.Category,
            Sort.Currency => p => p.Currency,
            Sort.Count => p => Stat(p.Name).Count,
            Sort.Value => p => Stat(p.Name).Total,
            _ => p => p.Name,
        };
        var ordered = _desc
            ? BillProfiles.All.OrderByDescending(key)
            : BillProfiles.All.OrderBy(key);
        return ordered.ThenBy(p => p.Name);   // stable, readable tie-break for the many 0-import rows
    }

    private RenderFragment SortHeader(Sort col, string label, string? style) => builder =>
    {
        builder.OpenElement(0, "th");
        builder.AddAttribute(1, "class", $"sortable{(_sort == col ? " sorted" : "")}");
        if (style is not null) builder.AddAttribute(2, "style", style);
        builder.AddAttribute(3, "onclick", EventCallback.Factory.Create(this, () => SortBy(col)));
        builder.AddContent(4, label);
        if (_sort == col)
        {
            builder.OpenElement(5, "span");
            builder.AddAttribute(6, "class", "sort-caret");
            builder.AddContent(7, _desc ? "▼" : "▲");
            builder.CloseElement();
        }
        builder.CloseElement();
    };

    // The behaviour flags, spelled out — these change what gets imported and were invisible before.
    private static List<(string Label, string Help)> Flags(BillProfile p)
    {
        var f = new List<(string, string)>();
        if (p.FromPdf) f.Add(("PDF", "Amount is read from the attached PDF; falls back to the email body when there's no attachment"));
        if (p.Preferred) f.Add(("preferred", "Swept first so it wins dedup against the merchant's own email"));
        if (p.AllowZero) f.Add(("allows 0.00", "A zero total is imported instead of skipped"));
        if (p.Refund) f.Add(("refund +", "Posted as a positive transaction and exempt from dedup"));
        if (p.NoDedup) f.Add(("no dedup", "Parallel subscriptions: same amount on the same day is not a duplicate"));
        if (p.CategoryRules is not null) f.Add(("routed", "Category is read from the bill text, not fixed"));
        return f;
    }

    // Re-reads bill-profiles.xml. A bad file is rejected whole and the running set is kept, so the
    // worst case here is the error message below — never a half-loaded profile set.
    private void ReloadProfiles()
    {
        var path = BillProfiles.SourcePath
            ?? Path.Combine(AppContext.BaseDirectory, BillProfiles.LiveFileName);
        _reloadMsg = BillProfiles.Reload(path)
            ? $"Loaded {BillProfiles.All.Count} profiles."
            : $"Not reloaded — {BillProfiles.LoadError} (previous {BillProfiles.All.Count} still in use)";
    }

    // Fire-and-forget: the worker serializes concurrent runs, and progress shows in the banner above.
    private void ImportNow()
    {
        if (!BillMail.IsRunning)
            _ = Task.Run(() => BillMail.RunOnceAsync());
    }

    public void Dispose() => _timer?.Dispose();
}
