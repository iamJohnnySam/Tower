@using Tower.Core.State
@using Tower.Core.Metrics
@using Tower.Components.Shared
@inject LiveState Live
@implements IAsyncDisposable

<div class="atom-section">

    @{ var s = Live.Stats; }

    @* ── Partitions ───────────────────────────────────────────────────────────── *@
    <div class="atom-section-block">
        <div class="atom-block-title">Mounted Partitions</div>
        @if (s.Partitions.Count == 0)
        {
            <div class="atom-sub">No partition data available.</div>
        }
        else
        {
            <div class="partition-list">
                @foreach (var p in s.Partitions.OrderBy(x => x.Mount))
                {
                    <div class="partition-row">
                        <div class="partition-header">
                            <span class="partition-mount">@p.Mount</span>
                            <span class="partition-fstype text-muted">@p.Fstype</span>
                            <span class="partition-usage @DiskClass(p.Pct)">
                                @Fmt.Bytes(p.UsedBytes) / @Fmt.Bytes(p.TotalBytes) (@Fmt.PctInt(p.Pct))
                            </span>
                        </div>
                        <div class="mc-bar-wrap">
                            <div class="mc-bar">
                                <div class="mc-bar-fill @DiskClass(p.Pct)" style="width:@($"{Math.Min(p.Pct,100):0.#}%")"></div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    @* ── Physical Disks (SMART) ───────────────────────────────────────────────── *@
    <div class="atom-section-block">
        <div class="atom-block-title">Physical Disks (SMART)</div>
        @if (!Live.Disks.Any())
        {
            <div class="atom-sub">No disk data available yet.</div>
        }
        else
        {
            <div class="disk-cards">
                @foreach (var disk in Live.Disks)
                {
                    var borderColor = disk.Alert == 2 ? "#f85149" : disk.Alert == 1 ? "#d29922" : "#30363d";
                    <div class="disk-card" style="border-left: 3px solid @borderColor">
                        <div class="disk-card-header">
                            <span class="disk-model">@disk.Model</span>
                            <AlertBadge Level="@disk.Alert" Text="@DiskAlertText(disk.Alert)" />
                        </div>
                        <div class="disk-details">
                            <div class="atom-row-kv">
                                <span>Health</span>
                                <span class="@(disk.Health == "PASSED" ? "val-green" : "val-red")">@disk.Health</span>
                            </div>
                            <div class="atom-row-kv">
                                <span>Type</span>
                                <span>@(disk.Ssd ? "SSD" : "HDD")</span>
                            </div>
                            @if (disk.Temp.HasValue)
                            {
                                <div class="atom-row-kv">
                                    <span>Temp</span>
                                    <span class="@TempClass(disk.Temp.Value)">@disk.Temp.Value°C</span>
                                </div>
                            }
                            @if (disk.PowerOnHours.HasValue)
                            {
                                <div class="atom-row-kv">
                                    <span>Power-On</span>
                                    <span>@disk.PowerOnHours.Value h (@(disk.PowerOnHours.Value / 24) days)</span>
                                </div>
                            }
                            @if (disk.PowerCycles.HasValue)
                            {
                                <div class="atom-row-kv">
                                    <span>Power Cycles</span>
                                    <span>@disk.PowerCycles.Value</span>
                                </div>
                            }
                            @if (disk.Reallocated.HasValue && disk.Reallocated.Value > 0)
                            {
                                <div class="atom-row-kv">
                                    <span>Reallocated</span>
                                    <span class="val-amber">@disk.Reallocated.Value</span>
                                </div>
                            }
                            @if (disk.Pending.HasValue && disk.Pending.Value > 0)
                            {
                                <div class="atom-row-kv">
                                    <span>Pending</span>
                                    <span class="val-amber">@disk.Pending.Value</span>
                                </div>
                            }
                            @if (disk.Uncorrectable.HasValue && disk.Uncorrectable.Value > 0)
                            {
                                <div class="atom-row-kv">
                                    <span>Uncorrectable</span>
                                    <span class="val-red">@disk.Uncorrectable.Value</span>
                                </div>
                            }
                            @if (disk.Wear.HasValue)
                            {
                                <div class="atom-row-kv">
                                    <span>Wear</span>
                                    <span>@disk.Wear.Value%</span>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(disk.Serial))
                            {
                                <div class="atom-row-kv">
                                    <span>Serial</span>
                                    <span class="mono text-muted">@disk.Serial</span>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    @* ── Root-FS Usage Breakdown ──────────────────────────────────────────────── *@
    <div class="atom-section-block">
        <div class="atom-block-title">Filesystem Usage Breakdown</div>
        <div class="du-columns">

            <div class="du-col">
                <div class="du-col-title">Root ( / )</div>
                @if (!Live.RootSegments.Any())
                {
                    <div class="atom-sub text-muted">Collecting…</div>
                }
                else
                {
                    @foreach (var item in Live.RootSegments)
                    {
                        <div class="du-item">
                            <span class="du-name">@item.Name</span>
                            <span class="du-size">@Fmt.Bytes(item.Size)</span>
                        </div>
                    }
                }
            </div>

            <div class="du-col">
                <div class="du-col-title">/var</div>
                @if (!Live.VarSegments.Any())
                {
                    <div class="atom-sub text-muted">Collecting…</div>
                }
                else
                {
                    @foreach (var item in Live.VarSegments)
                    {
                        <div class="du-item">
                            <span class="du-name">@item.Name</span>
                            <span class="du-size">@Fmt.Bytes(item.Size)</span>
                        </div>
                    }
                }
            </div>

            <div class="du-col">
                <div class="du-col-title">Projects</div>
                @if (!Live.ProjectSizes.Any())
                {
                    <div class="atom-sub text-muted">Collecting…</div>
                }
                else
                {
                    @foreach (var item in Live.ProjectSizes)
                    {
                        <div class="du-item">
                            <span class="du-name">@item.Name</span>
                            <span class="du-size">@Fmt.Bytes(item.Size)</span>
                        </div>
                    }
                }
            </div>

        </div>
    </div>

</div>

@code {
    private System.Threading.Timer? _timer;

    protected override void OnInitialized()
    {
        _timer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(5), TimeSpan.FromSeconds(5));
    }

    public async ValueTask DisposeAsync()
    {
        if (_timer != null)
            await _timer.DisposeAsync();
    }

    static string DiskClass(double pct)  => pct > 90 ? "val-red" : pct > 80 ? "val-amber" : "val-green";
    static string TempClass(double c)    => c > 50 ? "val-red" : c > 40 ? "val-amber" : "val-green";
    static string DiskAlertText(int lvl) => lvl switch { 2 => "Critical", 1 => "Warning", _ => "OK" };
}
